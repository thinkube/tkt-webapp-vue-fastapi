# Test environment variables
PROJECT_NAME="Test Application"
FRONTEND_URL="http://localhost:8080"
BACKEND_CORS_ORIGINS='["http://localhost:8080"]'

# Test Keycloak settings (not used in tests but required by settings)
KEYCLOAK_URL="https://auth.test.com"
KEYCLOAK_REALM="test"
KEYCLOAK_CLIENT_ID="test-client"
KEYCLOAK_CLIENT_SECRET="test-secret"

# Test database settings - PostgreSQL in cluster
# DATABASE_URL will be constructed by config.py from these variables
POSTGRES_HOST="postgresql-official.postgres.svc.cluster.local"
POSTGRES_PORT="5432"
POSTGRES_DB="test_app_db"
# POSTGRES_USER and POSTGRES_PASSWORD will be set from environment

# Test secret key
SECRET_KEY="test-secret-key-for-testing-only"